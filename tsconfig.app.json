{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,

    "lib": ["ES2020", "DOM", "DOM.Iterable"],

    "module": "ESNext",
    "moduleResolution": "bundler",

    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",

    "noEmit": true,
    "jsx": "react-jsx",

    "skipLibCheck": true,

    /* Strictness (relaxed for now) */
    "strict": false,
    "noImplicitAny": false,

    /* Path aliases */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },

  "include": ["src"]
}